import requests
import base64

def get_falcon_oauth_token(client_id, client_secret, region):
    """Get OAuth2 token from CrowdStrike Falcon API"""
    base_urls = {
        'us-1': 'https://api.crowdstrike.com',
        'us-2': 'https://api.us-2.crowdstrike.com',
        'eu-1': 'https://api.eu-1.crowdstrike.com',
        'us-gov-1': 'https://api.laggar.gcw.crowdstrike.com'
    }
    base_url = base_urls.get(region, 'https://api.crowdstrike.com')
    token_url = f"{base_url}/oauth2/token"
    auth_string = f"{client_id}:{client_secret}"
    encoded_auth = base64.b64encode(auth_string.encode()).decode()

    headers = {
        'Authorization': f'Basic {encoded_auth}',
        'Content-Type': 'application/x-www-form-urlencoded'
    }
    data = {'grant_type': 'client_credentials'}

    try:
        response = requests.post(token_url, headers=headers, data=data, timeout=30)
        response.raise_for_status()
        return response.json().get('access_token'), base_url
    except Exception as e:
        print(f"⚠️  Failed to get OAuth token: {e}")
        return None, base_url

def get_container_image_id(token, base_url, image_name, image_tag):
    """Get container image ID from registry"""
    url = f"{base_url}/container-security/combined/images/export/v1"
    headers = {'Authorization': f'Bearer {token}'}
    params = {'filter': f"repository:'{image_name}'+tag:'{image_tag}'", 'limit': 1}

    try:
        response = requests.get(url, headers=headers, params=params, timeout=30)
        response.raise_for_status()
        data = response.json()
        resources = data.get('resources', [])
        if resources:
            return resources[0].get('id')
    except Exception as e:
        print(f"⚠️  Failed to get image ID: {e}")
    return None

def get_image_vulnerabilities_from_api(token, base_url, image_id):
    """Fetch container image vulnerabilities from CrowdStrike API"""
    url = f"{base_url}/container-security/combined/vulnerabilities/details/v1"
    headers = {'Authorization': f'Bearer {token}'}
    params = {'filter': f"image_id:'{image_id}'", 'limit': 500}

    try:
        print(f"🔍 Fetching vulnerabilities from API for image ID: {image_id}")
        response = requests.get(url, headers=headers, params=params, timeout=60)
        response.raise_for_status()
        return response.json().get('resources', [])
    except Exception as e:
        print(f"❌ Failed to fetch from API: {e}")
        return []

