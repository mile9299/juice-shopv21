"""

    # Sort and display top 20
    severity_order = {'CRITICAL': 0, 'HIGH': 1, 'MEDIUM': 2, 'LOW': 3, 'UNKNOWN': 4}

    def get_sev(v):
        if 'severity' in v: return v['severity'].upper()
        if 'Details' in v:
            cps = v.get('Details', {}).get('cps_rating', {}).get('CurrentRating', {})
            if 'Rating' in cps: return cps['Rating'].upper()
        return 'UNKNOWN'

    sorted_vulns = sorted(vulnerabilities, key=lambda x: severity_order.get(get_sev(x), 4))[:20]

    for vuln in sorted_vulns:
        sev = get_sev(vuln)
        cve = vuln.get('CVEID', vuln.get('cve_id', 'N/A'))

        if 'Product' in vuln:
            prod = vuln['Product']
            pkg = prod.get('PackageSource', 'Unknown') if isinstance(prod, dict) else str(prod)
        else:
            pkg = vuln.get('package_name', 'Unknown')

        is_rem = False
        if 'Remediation' in vuln:
            rem = vuln['Remediation']
            if rem and rem not in ['', {}, [], None, 'none', 'n/a']:
                is_rem = True

        rem_display = '<span style="color: #4EC9B0; font-weight: 600;">Yes</span>' if is_rem else '<span style="color: #8B949E; font-weight: 500;">No</span>'
        sev_class = f"severity-{sev.lower()}"

        html += f'<tr><td class="{sev_class}">{sev}</td><td>{cve}</td><td>{pkg}</td><td>{rem_display}</td></tr>'

    html += """
      </tbody>
  </table>
</div>
<div class="footer"><strong>🛡️ CrowdStrike Falcon Cloud Security</strong><br>Container Image Security Assessment</div>
</div>
</body>
</html>
